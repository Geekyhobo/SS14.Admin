@page "/bans/{BanId:int}/hits"
@using Microsoft.AspNetCore.Components.QuickGrid

<PageTitle>Ban Hits</PageTitle>

<div class="min-h-screen">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 px-4 sm:px-6 pt-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 flex items-center gap-3">
                <i class="fas fa-gavel text-red-600 dark:text-red-500"></i>
                Ban Hits for Ban #@Ban?.Id
            </h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">View connection hits for this ban</p>
        </div>
    </div>

    @if (Ban != null)
    {
        <!-- Ban Info -->
        <div class="px-4 sm:px-6 mb-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <dl class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Name</dt>
                        <dd class="text-base text-gray-900 dark:text-gray-100 mt-1">@(Ban.PlayerName ?? "Unknown")</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">User ID</dt>
                        <dd class="text-base font-mono text-gray-900 dark:text-gray-100 mt-1">@Ban.PlayerUserId</dd>
                    </div>
                    @if (ShowPII)
                    {
                        <div>
                            <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">IP Address</dt>
                            <dd class="text-base font-mono text-gray-900 dark:text-gray-100 mt-1">@Ban.IPAddress</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">HWID</dt>
                            <dd class="text-base font-mono text-gray-900 dark:text-gray-100 mt-1">@Ban.Hwid</dd>
                        </div>
                    }
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Reason</dt>
                        <dd class="text-base text-gray-900 dark:text-gray-100 mt-1">@(Ban.Reason ?? "No reason provided")</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Ban Time</dt>
                        <dd class="text-base text-gray-900 dark:text-gray-100 mt-1">@Ban.BanTime.ToString("yyyy-MM-dd HH:mm:ss")</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Expires</dt>
                        <dd class="text-base mt-1">
                            @if (Ban.ExpirationTime.HasValue)
                            {
                                <span class="text-gray-900 dark:text-gray-100">@Ban.ExpirationTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                @if (Ban.ExpirationTime < DateTime.UtcNow)
                                {
                                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300">Expired</span>
                                }
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300">PERMANENT</span>
                            }
                            @if (Ban.UnbanTime.HasValue)
                            {
                                <div class="mt-1 text-sm">
                                    <span class="font-semibold text-gray-700 dark:text-gray-300">Unbanned:</span>
                                    <span class="text-gray-900 dark:text-gray-100">@Ban.UnbanTime.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                    @if (!string.IsNullOrEmpty(Ban.UnbanAdmin))
                                    {
                                        <span class="text-gray-600 dark:text-gray-400"> by @Ban.UnbanAdmin</span>
                                    }
                                </div>
                            }
                        </dd>
                    </div>
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Banning Admin</dt>
                        <dd class="text-base text-gray-900 dark:text-gray-100 mt-1">@(Ban.Admin ?? "Unknown")</dd>
                    </div>
                </dl>
            </div>
        </div>

        <!-- Connection Hits Section -->
        <div class="px-4 sm:px-6 mb-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
                <div class="p-4 border-b border-gray-200 dark:border-gray-700">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Connection Hits</h2>
                        <input type="text"
                               @bind="_searchText"
                               @bind:event="oninput"
                               placeholder="Search by username or user ID..."
                               class="w-full sm:w-64 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <QuickGrid TItem="ConnectionHitViewModel"
                               @ref="Grid"
                               Items="@GetFilteredConnections()"
                               Pagination="@_pagination"
                               Class="w-full text-sm">
                        <PropertyColumn Property="@(c => c.UserName)" Title="Username" Sortable="true" class="text-gray-700 dark:text-gray-300 px-4 py-2 whitespace-nowrap" />
                        <PropertyColumn Property="@(c => c.UserId)" Title="User ID" Sortable="true" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap font-mono" />
                        @if (ShowPII)
                        {
                            <PropertyColumn Property="@(c => c.Address)" Title="IP Address" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap font-mono" />
                            <PropertyColumn Property="@(c => c.HWId)" Title="HWID" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap font-mono" />
                        }
                        <PropertyColumn Property="@(c => c.Time)" Title="Connection Time" Format="yyyy-MM-dd HH:mm:ss" Sortable="true" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap" />
                        <PropertyColumn Property="@(c => c.ServerName)" Title="Server" Sortable="true" class="text-gray-700 dark:text-gray-300 px-4 py-2 whitespace-nowrap" />
                        <TemplateColumn Title="Status" class="px-4 py-2 whitespace-nowrap">
                            <div class="flex justify-center">
                            @if (context.Denied.HasValue)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300">
                                    <i class="fas fa-times-circle mr-1"></i> @context.Denied.Value.ToString()
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300">
                                    <i class="fas fa-check-circle mr-1"></i> Accepted
                                </span>
                            }
                            </div>
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700/50 border-t border-gray-200 dark:border-gray-700 px-4 py-2">
                    <Pagination State="@_pagination" OnRefreshRequired="@RefreshGrid" />
                </div>
            </div>
        </div>
    }
    else if (_loading)
    {
        <div class="flex items-center justify-center min-h-[400px]">
            <div class="text-center">
                <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
                <p class="text-gray-600 dark:text-gray-400 text-lg">Loading ban information...</p>
            </div>
        </div>
    }
    else
    {
        <div class="px-4 sm:px-6">
            <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 text-red-700 dark:text-red-300 p-4 rounded-lg shadow-md">
                <div class="flex items-center">
                    <i class="fas fa-exclamation-circle text-xl mr-3"></i>
                    <div>
                        <strong class="font-semibold">Ban not found!</strong>
                        <p class="text-sm mt-1">The requested ban does not exist.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
