@page "/bans"
@using Microsoft.AspNetCore.Components.QuickGrid
@using SS14.Admin.Admins
@using SS14.Admin.Helpers
@using SS14.Admin.Components.Forms

<PageTitle>Bans</PageTitle>

<div class="min-h-screen">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 px-4 sm:px-6 pt-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 flex items-center gap-3">
                <i class="ri-shield-cross-fill text-red-600 dark:text-red-500"></i>
                Bans
            </h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">Manage player bans</p>
        </div>
        <div class="flex gap-3">
            <AuthorizeView Roles="@AdminFlags.Ban.RoleName()">
                <Authorized>
                    <NavLink href="/bans/createban"
                             class="inline-flex items-center px-3 py-1.5 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white rounded-lg font-medium shadow-md transition-all duration-200 text-sm">
                        <i class="ri-shield-cross-fill text-red-600 dark:text-red-500 mr-2"></i>
                        Create New Ban
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="px-4 sm:px-6 mb-4">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
            <div class="p-3">
                <BanFilter Filter="_model" FormName="banFilter" OnSubmit="@OnFilterSubmit" />
            </div>
        </div>
    </div>

    <!-- Column Visibility Toggles -->
    <div class="px-4 sm:px-6 mb-4 flex flex-wrap items-center gap-2">
        <span class="text-sm text-gray-600 dark:text-gray-400 font-medium">Show/Hide:</span>
        <button @onclick="() => _showIpColumn = !_showIpColumn"
                class="inline-flex items-center px-2 py-1 rounded text-xs font-medium transition-colors @(_showIpColumn ? "bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300" : "bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400")">
            <i class="@(_showIpColumn ? "fas fa-check-square mr-1" : "far fa-square mr-1")"></i>
            IP
        </button>
        <button @onclick="() => _showHwidColumn = !_showHwidColumn"
                class="inline-flex items-center px-2 py-1 rounded text-xs font-medium transition-colors @(_showHwidColumn ? "bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300" : "bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400")">
            <i class="@(_showHwidColumn ? "fas fa-check-square mr-1" : "far fa-square mr-1")"></i>
            HWID
        </button>
        <button @onclick="() => _showGuidColumn = !_showGuidColumn"
                class="inline-flex items-center px-2 py-1 rounded text-xs font-medium transition-colors @(_showGuidColumn ? "bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300" : "bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400")">
            <i class="@(_showGuidColumn ? "fas fa-check-square mr-1" : "far fa-square mr-1")"></i>
            GUID
        </button>
    </div>

    <!-- Bans Table -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden mx-4 sm:mx-6 mb-4">
        <div class="overflow-x-auto">
            <QuickGrid TItem="BanViewModel"
                       @ref="Grid"
                       Items="@_bansList.AsQueryable()"
                       Pagination="@_pagination"
                       Class="w-full text-sm">
                <PropertyColumn Property="@(ban => ban.PlayerName)" Title="Name" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                @if (_showIpColumn)
                {
                    <PropertyColumn Property="@(ban => RedactIp(ban.IPAddress))" Title="IP" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                }
                @if (_showHwidColumn)
                {
                    <PropertyColumn Property="@(ban => RedactHwid(ban.Hwid))" Title="HWID" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                }
                @if (_showGuidColumn)
                {
                    <PropertyColumn Property="@(ban => ban.PlayerUserId)" Title="GUID" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                }
                <PropertyColumn Property="@(ban => ban.Reason)" Title="Reason" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                <PropertyColumn Property="@(ban => ban.BanTime)" Title="Ban Time" Format="yyyy-MM-dd HH:mm" Sortable="true" class="text-gray-600 dark:text-gray-400 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                <PropertyColumn Property="@(ban => ban.ExpirationTime)" Title="Expires" Format="yyyy-MM-dd HH:mm" Sortable="true" class="text-gray-600 dark:text-gray-400 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                <PropertyColumn Property="@(ban => ban.Admin)" Title="Admin" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap"></PropertyColumn>
                <TemplateColumn Title="Hits" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap">
                    @if (context.HitCount > 0)
                    {
                        <NavLink href="@($"/bans/{context.Id.ToString()}/hits")"
                                 class="inline-flex items-center gap-1 px-2 py-1 bg-sky-400 hover:bg-sky-500 dark:bg-sky-600 dark:hover:bg-sky-700 text-white rounded text-xs font-medium transition-colors">
                            @context.HitCount
                        </NavLink>
                    }
                    else
                    {
                        <span class="text-gray-400 dark:text-gray-500">0</span>
                    }
                </TemplateColumn>
                <TemplateColumn Title="Actions" class="text-gray-700 dark:text-gray-300 px-2 py-2 whitespace-nowrap">
                    <div class="flex justify-center">
                    @if (context.Active)
                    {
                        @if (!_confirmations.ContainsKey(context.Id) || !_confirmations[context.Id])
                        {
                            <button class="inline-flex items-center justify-center gap-1 px-2 py-1 bg-yellow-500 hover:bg-yellow-600 dark:bg-yellow-600 dark:hover:bg-yellow-700 text-white rounded text-xs font-medium transition-colors"
                                    @onclick="() => ShowConfirmation(context.Id, context.Active)">
                                Unban
                            </button>
                        }
                        else
                        {
                            <button class="inline-flex items-center justify-center gap-1 px-2 py-1 bg-red-500 hover:bg-red-600 dark:bg-red-600 dark:hover:bg-red-700 text-white rounded text-xs font-medium transition-colors"
                                    @onclick="() => ConfirmAction(context.Id, context.Active)">
                                Confirm?
                            </button>
                        }
                    }
                    else
                    {
                        <span class="text-gray-400 dark:text-gray-500 italic text-xs">
                            Ubanned
                        </span>
                    }
                    </div>
                </TemplateColumn>
            </QuickGrid>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 border-t border-gray-200 dark:border-gray-700 px-4 py-2">
            <Pagination OnRefreshRequired="Refresh" State="@_pagination"/>
        </div>
    </div>
</div>
