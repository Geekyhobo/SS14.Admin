@page "/connections/{ConnectionId:int}/hits"
@using Microsoft.AspNetCore.Components.QuickGrid

<PageTitle>Connection Ban Hits</PageTitle>

<div class="min-h-screen">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 px-4 sm:px-6 pt-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 flex items-center gap-3">
                <i class="fas fa-gavel text-red-600 dark:text-red-500"></i>
                Bans Hit for Connection #@Connection?.Id
            </h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">View ban history for this connection</p>
        </div>
    </div>

    @if (Connection != null)
    {
        <!-- Connection Info -->
        <div class="px-4 sm:px-6 mb-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
                <dl class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Username</dt>
                        <dd class="text-base text-gray-900 dark:text-gray-100 mt-1">@Connection.UserName</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">User ID</dt>
                        <dd class="text-base font-mono text-gray-900 dark:text-gray-100 mt-1">@Connection.UserId</dd>
                    </div>
                    @if (ShowPII)
                    {
                        <div>
                            <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">IP Address</dt>
                            <dd class="text-base font-mono text-gray-900 dark:text-gray-100 mt-1">@Connection.Address</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">HWID</dt>
                            <dd class="text-base font-mono text-gray-900 dark:text-gray-100 mt-1">@Connection.HWId</dd>
                        </div>
                    }
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Connection Time</dt>
                        <dd class="text-base text-gray-900 dark:text-gray-100 mt-1">@Connection.Time.ToString("yyyy-MM-dd HH:mm:ss")</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Server</dt>
                        <dd class="text-base text-gray-900 dark:text-gray-100 mt-1">@Connection.ServerName</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Status</dt>
                        <dd class="text-base mt-1">
                            @if (Connection.Denied.HasValue)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300">
                                    <i class="fas fa-times-circle mr-1"></i> @Connection.Denied.Value.ToString()
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300">
                                    <i class="fas fa-check-circle mr-1"></i> Accepted
                                </span>
                            }
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

        <!-- Bans Hit Section -->
        <div class="px-4 sm:px-6 mb-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
                <div class="p-4 border-b border-gray-200 dark:border-gray-700">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Bans Hit</h2>
                        <input type="text"
                               @bind="_searchText"
                               @bind:event="oninput"
                               placeholder="Search bans..."
                               class="w-full sm:w-64 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <QuickGrid TItem="BanHitViewModel"
                               @ref="Grid"
                               Items="@GetFilteredBans()"
                               Pagination="@_pagination"
                               Class="w-full text-sm">
                        <PropertyColumn Property="@(b => b.PlayerName)" Title="Player Name" Sortable="true" class="text-gray-700 dark:text-gray-300 px-4 py-2 whitespace-nowrap" />
                        <PropertyColumn Property="@(b => b.PlayerUserId)" Title="User ID" Sortable="true" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap font-mono" />
                        @if (ShowPII)
                        {
                            <PropertyColumn Property="@(b => b.IPAddress)" Title="IP Address" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap font-mono" />
                            <PropertyColumn Property="@(b => b.Hwid)" Title="HWID" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap font-mono" />
                        }
                        <PropertyColumn Property="@(b => b.Reason)" Title="Reason" class="text-gray-600 dark:text-gray-400 px-4 py-2 max-w-xs truncate" />
                        <PropertyColumn Property="@(b => b.BanTime)" Title="Ban Time" Format="yyyy-MM-dd HH:mm:ss" Sortable="true" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap" />
                        <PropertyColumn Property="@(b => b.ExpirationTime)" Title="Expires" Format="yyyy-MM-dd HH:mm:ss" Sortable="true" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap" />
                        <PropertyColumn Property="@(b => b.RoundId)" Title="Round" class="text-gray-600 dark:text-gray-400 px-4 py-2 whitespace-nowrap" />
                        <PropertyColumn Property="@(b => b.Admin)" Title="Banning Admin" class="text-gray-700 dark:text-gray-300 px-4 py-2 whitespace-nowrap" />
                        <TemplateColumn Title="Ban Hits" class="px-4 py-2 whitespace-nowrap">
                            @if (context.HitCount > 0)
                            {
                                <NavLink href="@($"/bans/{context.Id}/hits")" class="inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 hover:underline font-semibold">
                                    @context.HitCount
                                </NavLink>
                            }
                            else
                            {
                                <span class="text-gray-400 dark:text-gray-500">0</span>
                            }
                        </TemplateColumn>
                        <TemplateColumn Title="Actions" class="px-4 py-2 whitespace-nowrap">
                            <div class="flex justify-center">
                            @if (context.Active)
                            {
                                @if (!_confirmations.ContainsKey(context.Id) || !_confirmations[context.Id])
                                {
                                    <button class="inline-flex items-center justify-center gap-1 px-3 py-1.5 bg-sky-400 hover:bg-sky-500 dark:bg-sky-600 dark:hover:bg-sky-700 text-white rounded-md text-sm font-medium transition-colors"
                                            @onclick="() => ShowConfirmation(context.Id)">
                                        <i class="fas fa-unlock"></i> Unban
                                    </button>
                                }
                                else
                                {
                                    <button class="inline-flex items-center justify-center gap-1 px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white rounded-md text-sm font-medium transition-colors"
                                            @onclick="() => ConfirmUnban(context.Id)">
                                        <i class="fas fa-question-circle"></i> Confirm?
                                    </button>
                                }
                            }
                            else
                            {
                                <span class="text-gray-400 dark:text-gray-500 italic text-sm">Already unbanned/expired</span>
                            }
                            </div>
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700/50 border-t border-gray-200 dark:border-gray-700 px-4 py-2">
                    <Pagination State="@_pagination" OnRefreshRequired="@RefreshGrid" />
                </div>
            </div>
        </div>
    }
    else if (_loading)
    {
        <div class="flex items-center justify-center min-h-[400px]">
            <div class="text-center">
                <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
                <p class="text-gray-600 dark:text-gray-400 text-lg">Loading connection information...</p>
            </div>
        </div>
    }
    else
    {
        <div class="px-4 sm:px-6">
            <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 text-red-700 dark:text-red-300 p-4 rounded-lg shadow-md">
                <div class="flex items-center">
                    <i class="fas fa-exclamation-circle text-xl mr-3"></i>
                    <div>
                        <strong class="font-semibold">Connection not found!</strong>
                        <p class="text-sm mt-1">The requested connection does not exist.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
