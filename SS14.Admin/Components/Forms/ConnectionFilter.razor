
<EditForm Model="@Filter" FormName="@FormName" OnSubmit="@Submit" class="flex gap-4 items-end flex-wrap">
    <div class="flex flex-col gap-1">
        <label for="filter-search" class="text-sm font-semibold text-gray-700 dark:text-gray-300">Search</label>
        <InputText @bind-Value="Filter.Search"
                   id="filter-search"
                   placeholder="Username or GUID"
                   class="w-80 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
    </div>
    <div class="flex flex-col gap-1">
        <label for="filter-date-from" class="text-sm font-semibold text-gray-700 dark:text-gray-300">Date From</label>
        <InputDate @bind-Value="Filter.DateFrom"
                   id="filter-date-from"
                   class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
    </div>
    <div class="flex flex-col gap-1">
        <label for="filter-date-to" class="text-sm font-semibold text-gray-700 dark:text-gray-300">Date To</label>
        <InputDate @bind-Value="Filter.DateTo"
                   id="filter-date-to"
                   class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
    </div>
    <div class="flex flex-col gap-1">
        <label for="filter-server" class="text-sm font-semibold text-gray-700 dark:text-gray-300">Server ID</label>
        <InputNumber @bind-Value="Filter.ServerId"
                     id="filter-server"
                     class="w-24 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
    </div>
    <div class="flex gap-4 items-center border border-gray-200 dark:border-gray-600 rounded-lg px-4 py-2 bg-gray-50 dark:bg-gray-700/50">
        <span class="font-semibold text-gray-700 dark:text-gray-300 text-sm">Connection Types:</span>
        <label class="flex items-center gap-2 cursor-pointer">
            <InputCheckbox @bind-Value="Filter.ShowAccepted" id="show-accepted"
                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800" />
            <span class="text-sm text-gray-700 dark:text-gray-300">Accepted</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <InputCheckbox @bind-Value="Filter.ShowBanned" id="show-banned"
                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800" />
            <span class="text-sm text-gray-700 dark:text-gray-300">Banned</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <InputCheckbox @bind-Value="Filter.ShowWhitelist" id="show-whitelist"
                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800" />
            <span class="text-sm text-gray-700 dark:text-gray-300">Whitelist</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <InputCheckbox @bind-Value="Filter.ShowFull" id="show-full"
                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800" />
            <span class="text-sm text-gray-700 dark:text-gray-300">Full</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <InputCheckbox @bind-Value="Filter.ShowPanic" id="show-panic"
                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800" />
            <span class="text-sm text-gray-700 dark:text-gray-300">Panic</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <InputCheckbox @bind-Value="Filter.ShowBabyJail" id="show-babyjail"
                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800" />
            <span class="text-sm text-gray-700 dark:text-gray-300">BabyJail</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <InputCheckbox @bind-Value="Filter.ShowIPChecks" id="show-ipchecks"
                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800" />
            <span class="text-sm text-gray-700 dark:text-gray-300">IPChecks</span>
        </label>
    </div>
    <button type="submit" class="h-10 px-6 py-2 bg-gradient-to-r from-sky-500 to-sky-600 hover:from-sky-600 hover:to-sky-700 dark:from-sky-600 dark:to-sky-700 dark:hover:from-sky-700 dark:hover:to-sky-800 text-white rounded-lg font-medium shadow-md transition-all duration-200">
        <i class="ri-search-line mr-2"></i>Search
    </button>
</EditForm>

@code
{
    [Parameter] public ConnectionsFilterModel Filter { get; set; } = null!;
    [Parameter] public string FormName { get; set; } = null!;
    [Parameter] public EventCallback<EditContext> OnSubmit { get; set; } = EventCallback<EditContext>.Empty;

    private async Task Submit(EditContext arg) => await OnSubmit.InvokeAsync(arg);
}
