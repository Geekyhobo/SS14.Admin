@* WIP this css needs fixing to align with flex row but its not flex row on the admin pages consistency needs to be worked on *@
<EditForm Model="@Filter" FormName="@FormName" OnSubmit="@Submit" class="flex gap-4 items-end flex-wrap">
    <div class="flex flex-col gap-1">
        <label for="filter-search" class="text-sm font-semibold text-gray-700 dark:text-gray-300">Search Username</label>
        <InputText @bind-Value="Filter.Search"
                   id="filter-search"
                   placeholder="Username..."
                   class="w-48 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
    </div>
    <div class="flex flex-col gap-1">
        <label for="filter-rank" class="text-sm font-semibold text-gray-700 dark:text-gray-300">Rank</label>
        <InputText @bind-Value="Filter.Rank"
                   id="filter-rank"
                   placeholder="Rank..."
                   class="w-48 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-100" />
    </div>
    <div class="grow"></div>
    <button type="submit" class="h-10 px-6 py-2 bg-gradient-to-r from-sky-500 to-sky-600 hover:from-sky-600 hover:to-sky-700 dark:from-sky-600 dark:to-sky-700 dark:hover:from-sky-700 dark:hover:to-sky-800 text-white rounded-lg font-medium shadow-md transition-all duration-200">
        <i class="ri-search-line mr-2"></i>Search
    </button>
</EditForm>

@code
{
    [Parameter] public AdminFilterModel Filter { get; set; } = null!;
    [Parameter] public string FormName { get; set; } = null!;
    [Parameter] public EventCallback<EditContext> OnSubmit { get; set; } = EventCallback<EditContext>.Empty;

    private async Task Submit(EditContext arg) => await OnSubmit.InvokeAsync(arg);
}
